<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC 
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

 <hibernate-mapping>
   <class  name="com.demo.Mobile" table="mobileTable"> 
      <id  name="imeiNo"  column="IMEINO">
       <generator class="assigned"> </generator>
      </id>
      
      <property name="brand" column="mob_brand"> </property>
      <property name="price" column="mob_price"></property>
      <property name="model" column="mob_model"></property>
      <property name="colour" column="mob_colour"></property>
   
   
    </class>
 
 </hibernate-mapping>